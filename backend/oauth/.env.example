# OAuth Backend Configuration

# Яндекс OAuth credentials
# Получи на https://yandex.ru/dev/dialogs/
YANDEX_CLIENT_ID=your-client-id-from-yandex
YANDEX_CLIENT_SECRET=your-client-secret-from-yandex

# Твой backend (используется в OAuth redirect)
BACKEND_URL=https://твой.домен.kz

# Node-RED API (где Node-RED ставит слушает)
NODERED_URL=http://localhost:1881

# Secret для Node-RED API (защита endpoints)
NODERED_TOKEN=super-secret-nodered-token-change-in-prod

# JWT Secret для внутренних токенов
JWT_SECRET=super-secret-jwt-key-change-in-prod

# Порт, на котором запускать OAuth backend
PORT=3000
